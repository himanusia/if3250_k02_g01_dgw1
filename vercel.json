{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "bun install",
  "buildCommand": "bun --filter web build",
  "outputDirectory": "apps/web/dist/client",
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs22.x",
      "includeFiles": "apps/web/dist/server/**"
    }
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/api"
    }
  ]
}
